{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "types": ["node", "react", "lodash"],
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "environment.d.ts", "**/*.ts", "**/*.tsx", "pages/_document.js", "types/**.ts"],
  "exclude": ["node_modules"]
}
